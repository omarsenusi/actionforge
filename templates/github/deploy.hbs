name: Deploy Application

on:
  push:
    branches: [ main, master ]
  workflow_dispatch:

jobs:
  deploy:
    name: Deploy to Server
    runs-on: {{runnerLabel}}

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      {{#if (eq packageManager "pnpm")}}
      - name: Setup pnpm
        uses: pnpm/action-setup@v3
        with:
          version: 9
      {{/if}}

      {{#if (eq packageManager "bun")}}
      - name: Setup Bun
        uses: oven-sh/setup-bun@v2
        with:
          bun-version: latest
      {{/if}}

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '{{nodeVersion}}'
          {{#if (eq packageManager "npm")}}
          cache: 'npm'
          {{/if}}
          {{#if (eq packageManager "pnpm")}}
          cache: 'pnpm'
          {{/if}}
          {{#if (eq packageManager "yarn")}}
          cache: 'yarn'
          {{/if}}

      - name: Install dependencies
        run: {{installCommand}}

      - name: Build application
        run: {{buildCommand}}

      - name: Create deployment package
        run: |
          cd build && tar -czf ../build.tar.gz .

      - name: Copy files to Server via SCP
        uses: appleboy/scp-action@master
        with:
          host: $\{{ secrets.HOST }}
          username: $\{{ secrets.USERNAME }}
          key: $\{{ secrets.SSH_KEY }}
          port: $\{{ secrets.PORT }}
          source: "build.tar.gz,ecosystem.config.js"
          target: "{{deployPath}}/{{appName}}"

      - name: Execute remote SSH deployment commands
        uses: appleboy/ssh-action@master
        with:
          host: $\{{ secrets.HOST }}
          username: $\{{ secrets.USERNAME }}
          key: $\{{ secrets.SSH_KEY }}
          port: $\{{ secrets.PORT }}
          script: |
            # Load Node managers (NVM, FNM, etc.) to make Node, npm, and PM2 available in non-interactive sessions
            if [ -d "$HOME/.nvm" ]; then
              export NVM_DIR="$HOME/.nvm"
              [ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
            fi
            if [ -d "$HOME/.fnm" ]; then
              export PATH="$HOME/.fnm:$PATH"
              eval "$(fnm env)"
            fi
            if [ -d "$HOME/n" ]; then
              export N_PREFIX="$HOME/n"
              export PATH="$N_PREFIX/bin:$PATH"
            fi
            export PATH="$PATH:$HOME/.local/bin:$HOME/bin"


            APP_NAME="{{appName}}"
            DEPLOY_PATH="{{deployPath}}"
            RELEASE_NAME=$(date +%Y%m%d-%H%M%S)
            RELEASE_PATH="${DEPLOY_PATH}/${APP_NAME}/releases/${RELEASE_NAME}"
            SHARED_PATH="${DEPLOY_PATH}/${APP_NAME}/shared"
            CURRENT_PATH="${DEPLOY_PATH}/${APP_NAME}/current"

            echo "ЁЯЪА Starting release: ${RELEASE_NAME}"
            mkdir -p ${RELEASE_PATH}
            mkdir -p ${SHARED_PATH}/uploads
            mkdir -p ${SHARED_PATH}/logs

            # Extract release archive
            echo "ЁЯУж Extracting release archive..."
            tar -xzf ${DEPLOY_PATH}/${APP_NAME}/build.tar.gz -C ${RELEASE_PATH}
            rm ${DEPLOY_PATH}/${APP_NAME}/build.tar.gz

            # Symlink shared files
            echo "ЁЯФЧ Linking shared assets..."
            if [ -f "${SHARED_PATH}/.env" ]; then
              ln -sfn ${SHARED_PATH}/.env ${RELEASE_PATH}/.env
            else
              echo "тЪая╕П Warning: No .env file found in shared directory. Please create one at ${SHARED_PATH}/.env"
            fi
            
            # Persistent Uploads and Logs Linking (both root uploads and public uploads)
            ln -sfn ${SHARED_PATH}/uploads ${RELEASE_PATH}/uploads
            mkdir -p ${RELEASE_PATH}/public
            ln -sfn ${SHARED_PATH}/uploads ${RELEASE_PATH}/public/uploads
            ln -sfn ${SHARED_PATH}/logs ${RELEASE_PATH}/logs

            # Install production dependencies
            echo "ЁЯУе Installing production dependencies..."
            cd ${RELEASE_PATH}
            {{installCommand}} --omit=dev

            # Update current symlink
            echo "ЁЯФД Updating current symlink..."
            ln -sfn ${RELEASE_PATH} ${CURRENT_PATH}

            # Reload server using PM2
            echo "ЁЯФД Starting/Reloading PM2 service..."
            cd ${DEPLOY_PATH}/${APP_NAME}
            pm2 startOrReload ecosystem.config.js --update-env

            # Clean up old releases
            echo "ЁЯз╣ Cleaning up old releases (keeping last 5)..."
            cd ${DEPLOY_PATH}/${APP_NAME}/releases
            ls -t | tail -n +6 | xargs -r rm -rf

            echo "тЬЕ Deployment completed successfully!"

{{#if telegramNotifications}}
      - name: Send Telegram Success Notification
        if: success()
        run: |
          TEXT="тЬи *GitHub Actions CD Notification* тЬи%0A%0AЁЯЪА *Status:* CD Deployment Success%0AЁЯУ▒ *App:* \`{{appName}}\`%0AЁЯУж *Repository:* \`$\{{ github.repository }}\`%0AЁЯМ┐ *Branch:* \`$\{{ github.ref_name }}\`%0AЁЯОп *Commit:* \`$\{{ github.sha }}\`%0AЁЯЦея╕П *Deployment Path:* \`{{deployPath}}/{{appName}}\`%0A%0AЁЯОЙ *The application has been successfully built, deployed, and reloaded with PM2!*"
          curl -s -X POST https://api.telegram.org/bot$\{{ vars.TELEGRAM_BOT_TOKEN || secrets.TELEGRAM_BOT_TOKEN }}/sendMessage \
            -d chat_id=$\{{ vars.TELEGRAM_CHAT_ID || secrets.TELEGRAM_CHAT_ID }} \
            -d text="${TEXT}" \
            -d parse_mode="Markdown"

      - name: Send Telegram Failure Notification
        if: failure()
        run: |
          TEXT="тЬи *GitHub Actions CD Notification* тЬи%0A%0AтЭМ *Status:* CD Deployment Failed%0AЁЯУ▒ *App:* \`{{appName}}\`%0AЁЯУж *Repository:* \`$\{{ github.repository }}\`%0AЁЯМ┐ *Branch:* \`$\{{ github.ref_name }}\`%0AЁЯОп *Commit:* \`$\{{ github.sha }}\`%0AЁЯЦея╕П *Deployment Path:* \`{{deployPath}}/{{appName}}\`%0A%0AтЪая╕П *The deployment workflow has failed. Please check the GitHub Actions logs.*"
          curl -s -X POST https://api.telegram.org/bot$\{{ vars.TELEGRAM_BOT_TOKEN || secrets.TELEGRAM_BOT_TOKEN }}/sendMessage \
            -d chat_id=$\{{ vars.TELEGRAM_CHAT_ID || secrets.TELEGRAM_CHAT_ID }} \
            -d text="${TEXT}" \
            -d parse_mode="Markdown"
{{/if}}
