{
  "name": "actionforge",
  "version": "0.3.2",
  "description": "Generate professional GitHub Actions workflows automatically for modern frameworks.",
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "actionforge": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"templates/**/*.hbs\"",
    "prepare": "husky"
  },
  "keywords": [
    "github-actions",
    "ci-cd",
    "workflow-generator",
    "typescript",
    "devops",
    "nextjs",
    "nestjs",
    "adonisjs",
    "express",
    "fastify",
    "node"
  ],
  "author": "Omar Senusi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omarsenusi/actionforge.git"
  },
  "bugs": {
    "url": "https://github.com/omarsenusi/actionforge/issues"
  },
  "homepage": "https://github.com/omarsenusi/actionforge#readme",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "fs-extra": "^11.3.6",
    "handlebars": "^4.7.8",
    "inquirer": "^14.0.2",
    "ora": "^9.4.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "eslint": "^9.6.0",
    "globals": "^17.7.0",
    "husky": "^9.1.1",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.3",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^1.6.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
